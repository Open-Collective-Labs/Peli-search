{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pelisearch.dev/schemas/SearchRequest.json",
  "title": "SearchRequest",
  "type": "object",
  "properties": {
    "q": { "type": "string" },
    "query": { "$ref": "QueryClause.json" },
    "filters": { "type": "array", "items": { "$ref": "QueryClause.json" } },
    "sort": { "type": "array", "items": { "$ref": "#/$defs/SortField" } },
    "from": { "type": "integer", "minimum": 0 },
    "size": { "type": "integer", "minimum": 1 },
    "highlight": { "type": "boolean" }
  },
  "$defs": {
    "SortField": {
      "type": "object",
      "properties": {
        "field": { "type": "string" },
        "order": { "type": "string", "enum": ["Asc", "Desc"] }
      },
      "required": ["field"]
    }
  }
}
