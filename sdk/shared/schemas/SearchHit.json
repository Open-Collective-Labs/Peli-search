{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pelisearch.dev/schemas/SearchHit.json",
  "title": "SearchHit",
  "type": "object",
  "required": ["document_id", "score", "fields"],
  "properties": {
    "document_id": { "type": "string" },
    "score": { "type": "number" },
    "fields": { "type": "object", "additionalProperties": true },
    "highlights": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
